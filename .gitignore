# ==============================
# Unity 6.2 - Git Ignore
# ==============================

# OS-generated files
####################
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# ==============================
# Unity-generated folders
##########################
Library/
Temp/
Obj/
Build/
Builds/
Logs/
MemoryCaptures/

# ==============================
# User-specific files
#######################
UserSettings/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# ==============================
# Unity Package Manager cache
################################
Packages/com.unity.package-manager-ui/

# ==============================
# Asset meta files (keep for LFS)
# Large files (textures, audio, models) should use Git LFS
#####################################
# Track your large files using:
# git lfs track "*.png"
# git lfs track "*.wav"
# git lfs track "*.fbx"

# ==============================
# Keep these in Git
################################
# Assets and ProjectSettings must be committed!
Assets/
ProjectSettings/